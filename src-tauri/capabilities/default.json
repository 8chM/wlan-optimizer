{
  "$schema": "https://raw.githubusercontent.com/nicobao/tauri-v2-schema/refs/heads/main/capability.json",
  "identifier": "default",
  "description": "Default capability set for WLAN-Optimizer. Note: iperf3 sidecar uses args:true because multiple variable-length arg patterns cannot be expressed as a single positional allowlist. Security is enforced Rust-side via validate_server_ip() in src/measurement/iperf.rs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:window:default",
    "core:window:allow-close",
    "core:window:allow-set-title",
    "core:window:allow-set-size",
    "core:window:allow-set-fullscreen",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "dialog:allow-message",
    "dialog:allow-confirm",
    {
      "identifier": "shell:allow-execute",
      "allow": [
        {
          "name": "binaries/iperf3",
          "cmd": "binaries/iperf3",
          "sidecar": true,
          "args": true
        }
      ]
    }
  ]
}
