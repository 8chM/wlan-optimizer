    "svelte": "^5.0.0",
    "svelte-konva": "^1.0.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "@sveltejs/vite-plugin-svelte": "^4.0.0",
    "@testing-library/svelte": "^5.0.0",
    "jsdom": "^28.1.0",
    "svelte-check": "^4.0.0",
    "typescript": "^5.5.0",
    "vite": "^5.4.0",
